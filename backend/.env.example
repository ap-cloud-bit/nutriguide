# ============================================================
#  NutriGuide — Environment Variables
#  Copy this file: cp .env.example .env
#  Then fill in your values below.
#  NEVER commit .env to GitHub. It's already in .gitignore.
# ============================================================

# ── REQUIRED ─────────────────────────────────────────────────
# Get your free API key at: https://console.anthropic.com
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ── OPTIONAL ─────────────────────────────────────────────────
# PostgreSQL connection string from Supabase (or any Postgres)
# Format:  postgresql://user:password@host:5432/dbname
# Leave blank to use in-memory storage (fine for demo/testing)
DATABASE_URL=

# Change this to any long random string in production
SECRET_KEY=nutriguide-change-this-in-production
